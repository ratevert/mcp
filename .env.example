# Upstream Ratevert API. Use the public URL when running this server separately.
RATEVERT_MCP_API_BASE_URL=https://ratevert.com
RATEVERT_MCP_SITE_URL=https://ratevert.com
RATEVERT_MCP_PUBLIC_URL=https://ratevert.com/api/mcp
RATEVERT_MCP_DOCS_URL=https://ratevert.com/mcp
RATEVERT_MCP_PRIVACY_URL=https://ratevert.com/privacy-policy
RATEVERT_MCP_SUPPORT_EMAIL=info@ratevert.com

# Bind locally by default. Put a trusted reverse proxy in front of a public host.
RATEVERT_MCP_PORT=3010
RATEVERT_MCP_TRUST_PROXY=loopback
RATEVERT_MCP_ALLOWED_ORIGINS=https://ratevert.com,https://chatgpt.com,https://claude.ai
RATEVERT_MCP_REQUEST_BODY_LIMIT=64kb

# Anonymous, read-only public request limits.
RATE_FREE_ASSET_LIMIT=4
RATEVERT_MCP_RATE_LIMIT_MAX_REQUESTS=120
RATEVERT_MCP_RATE_LIMIT_WINDOW_MS=60000
RATEVERT_MCP_PAIR_RATE_LIMIT_MAX_REQUESTS=20
RATEVERT_MCP_PAIR_RATE_LIMIT_WINDOW_MS=300000
RATEVERT_MCP_MAX_COMPARISON_RATE_LIMIT_MAX_REQUESTS=10
RATEVERT_MCP_MAX_COMPARISON_RATE_LIMIT_WINDOW_MS=300000
